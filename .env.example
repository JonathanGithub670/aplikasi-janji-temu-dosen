APP_NAME=Laravel_Reservasi
APP_ENV=local
APP_KEY=base64:JdLBSugKnMm5PhIofGB2bPVUQZS2E6axcQMj+wD5QN4=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - Docker MySQL service
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=db_topsis
DB_USERNAME=root
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# Redis for Queue
QUEUE_CONNECTION=redis

# Redis for Cache
CACHE_STORE=redis

# Redis for Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Redis - Docker Redis service
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
